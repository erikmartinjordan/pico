{
  "name": "pico",
  "version": "0.0.0",
  "description": "Lightweight screen-capture & annotation tool for Windows, Linux, and experimental macOS builds",
  "main": "src/main.js",
  "author": "Erik Martín Jordán",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win --linux",
    "build:mac:legacy": "electron-builder --mac --config config/electron-builder.legacy-mac.cjs",
    "build:linux": "electron-builder --linux",
    "build:desktop": "electron-builder --win --linux",
    "start:pwa": "node scripts/serve-pwa.js",
    "start:web": "node scripts/serve-pwa.js"
  },
  "devDependencies": {
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "ffmpeg-static": "5.2.0",
    "gifski": "1.7.1"
  },
  "build": {
    "appId": "com.pico.screenshot",
    "productName": "pico",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "artifactName": "${productName}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "identity": null
    },
    "win": {
      "publisherName": [
        "Erik Martín Jordán"
      ],
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "${productName}-portable.${ext}",
      "icon": "build/icon.ico"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "extraResources": [
      {
        "from": "src/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "asarUnpack": [
      "node_modules/ffmpeg-static/**",
      "node_modules/gifski/**"
    ]
  }
}
