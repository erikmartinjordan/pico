{
  "name": "pico",
  "version": "0.0.0",
  "description": "Lightweight screen-capture & annotation tool for macOS and Windows",
  "main": "src/main.js",
  "author": "Erik Mart\u00edn Jord\u00e1n",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win",
    "build:mac:legacy": "electron-builder --mac --config electron-builder.legacy-mac.cjs"
  },
  "devDependencies": {
    "electron": "^34.5.8",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.pico.screenshot",
    "productName": "pico",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "artifactName": "${productName}-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns"
    },
    "win": {
      "publisherName": [
        "Erik Mart\u00edn Jord\u00e1n"
      ],
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "${productName}-portable.${ext}",
      "icon": "build/icon.ico"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "extraResources": [
      {
        "from": "src/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
